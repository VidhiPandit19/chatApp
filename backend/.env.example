PORT=5000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost

DB_NAME=chatapp_db
DB_USER=root
DB_PASSWORD=
DB_SYNC_ALTER=true

# JWT
JWT_SECRET=my_super_secret_key
JWT_EXPIRES_IN=7d

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000

# SMTP (required for OTP emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=ChatApp <your_email@gmail.com>

# OTP settings
PASSWORD_OTP_TTL_MINUTES=10
PASSWORD_OTP_MIN_GAP_SEC=60
PASSWORD_OTP_MAX_ATTEMPTS=5
PASSWORD_OTP_BLOCK_MINUTES=15

# Upload limits
MAX_FILE_SIZE=10485760
